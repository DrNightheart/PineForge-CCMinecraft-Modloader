-- pineforge_base/mod.lua
-- Stone layers, cave carving, and ore generation.

local mod = {}
mod.name    = "PineForge Base"
mod.version = "0.1.0"
mod.author  = "PineForge"

function mod.init(api, cfg)

    local caveType    = cfg.getString("cave_type",    "classic")  -- classic | none
    local oreGen      = cfg.getBool("ore_gen",        true)
    local layeredRock = cfg.getBool("layered_rock",   true)

    api.registerBlock("stone", {
        color       = colors.gray,
        color2      = colors.lightGray,
        saveChar    = "Z",
        displayName = "Stone",
        inHotbar    = true,
    })

    api.registerBlock("coal_ore", {
        color       = colors.gray,
        color2      = colors.black,
        saveChar    = "Y",
        displayName = "Coal Ore",
        inHotbar    = true,
    })

    api.registerBlock("iron_ore", {
        color       = colors.gray,
        color2      = colors.orange,
        saveChar    = "X",
        displayName = "Iron Ore",
        inHotbar    = true,
    })

    api.registerBlock("gold_ore", {
        color       = colors.gray,
        color2      = colors.yellow,
        saveChar    = "W",
        displayName = "Gold Ore",
        inHotbar    = true,
    })

    -- Arithmetic hash noise (no bitwise ops — Lua 5.1).
    local function rawNoise(x, y, z, seed)
        local n = (x * 374761393 + y * 1103515245 + z * 668265263 + seed * 2246822519) % 2147483647
        n = (n * 1664525 + 1013904223) % 2147483647
        n = (n * 1664525 + 1013904223) % 2147483647
        return n / 2147483647.0   -- 0..1
    end

    local function sampleNoise(wx, y, wz, seed, scale)
        local bx = math.floor(wx / scale)
        local by = math.floor(y  / scale)
        local bz = math.floor(wz / scale)
        local sum = 0
        for dx = 0, 1 do
            for dy = 0, 1 do
                for dz = 0, 1 do
                    sum = sum + rawNoise(bx+dx, by+dy, bz+dz, seed)
                end
            end
        end
        return sum / 8   -- 0..1
    end

    -- Two-octave cave value. Both must be near 0.5 to carve — keeps tunnels narrow.
    local function caveValue(wx, y, wz, seed, scaleF, scaleC)
        local v1 = sampleNoise(wx, y, wz, seed,          scaleF)   -- fine detail
        local v2 = sampleNoise(wx, y, wz, seed + 999983, scaleC)   -- coarse shape
        local d1 = math.abs(v1 - 0.5)
        local d2 = math.abs(v2 - 0.5)
        return d1, d2
    end


    local function placeOreBlob(cx, cy, cz, oreId, radius, replaceBlock, getBlock)
        for dx = -radius, radius do
            for dy = -radius, radius do
                for dz = -radius, radius do
                    if dx*dx + dy*dy + dz*dz <= radius*radius then
                        local b = getBlock(cx+dx, cy+dy, cz+dz)
                        if b and b.name == "pineforge_base:stone" then
                            replaceBlock(cx+dx, cy+dy, cz+dz, oreId)
                        end
                    end
                end
            end
        end
    end

    api.onWorldGen(function(chunkX, chunkZ, heightMap, setBlock, getBlock, replaceBlock, removeBlock)
        local cs   = api.raw.config.chunkSize
        local mhT  = api.raw.config.maxHeightTerrain
        local seed = api.raw.config.seed

        -- Noise scales proportional to world height so tunnel size stays sensible.
        local scaleF = math.max(3, math.floor(mhT / 5))   -- fine detail
        local scaleC = math.max(5, math.floor(mhT / 3))   -- coarse shape

        -- Stone always fills at least 60% of mhT so short hills still have deep stone.
        local minStoneTop = math.floor(mhT * 0.6)

        for a = 1, cs do
            for b = 1, cs do
                local wx      = chunkX * cs + a
                local wz      = chunkZ * cs + b
                local surface = math.floor(heightMap[a][b] * mhT)

                if layeredRock then
                    local stoneTop = math.max(minStoneTop, surface - 3)
                    for y = 0, stoneTop do
                        local existing = getBlock(wx, y, wz)
                        if existing and (existing.name == "dirt" or existing.name == "sand") then
                            replaceBlock(wx, y, wz, "pineforge_base:stone")
                        end
                    end
                end

                if caveType == "classic" then
                    for y = 2, surface - 1 do
                        local depth = surface - y
                        if depth >= 5 then
                            local d1, d2 = caveValue(wx, y, wz, seed, scaleF, scaleC)
                            if d1 < 0.08 and d2 < 0.12 then
                                local existing = getBlock(wx, y, wz)
                                if existing and existing.name == "pineforge_base:stone" then
                                    removeBlock(wx, y, wz)
                                end
                            end
                        end
                    end
                end
            end
        end

        if oreGen then
            math.randomseed(seed + chunkX * 7919 + chunkZ * 6271)
            local cs2 = cs

            for _ = 1, math.random(3, 6) do
                local ax = chunkX * cs2 + math.random(1, cs2)
                local ay = math.random(2, 8)
                local az = chunkZ * cs2 + math.random(1, cs2)
                placeOreBlob(ax, ay, az, "pineforge_base:coal_ore", 1, replaceBlock, getBlock)
            end

            for _ = 1, math.random(2, 4) do
                local ax = chunkX * cs2 + math.random(1, cs2)
                local ay = math.random(1, 6)
                local az = chunkZ * cs2 + math.random(1, cs2)
                placeOreBlob(ax, ay, az, "pineforge_base:iron_ore", 1, replaceBlock, getBlock)
            end

            if math.random(1, 3) == 1 then
                local ax = chunkX * cs2 + math.random(1, cs2)
                local ay = math.random(0, 3)
                local az = chunkZ * cs2 + math.random(1, cs2)
                placeOreBlob(ax, ay, az, "pineforge_base:gold_ore", 1, replaceBlock, getBlock)
            end
        end
    end)

end

return mod
